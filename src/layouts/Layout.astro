---
import "../styles/global.css";
import { translations, type Locale } from "../i18n/translations";

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
}

const { lang = "en", title, description } = Astro.props;
const meta = translations[lang].meta;
const resolvedTitle = title ?? meta.title;
const resolvedDescription = description ?? meta.description;

const siteUrl = Astro.site ?? new URL("https://acabreram.me");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang={lang} data-theme="dark" class="bg-background text-text">
  <head>
    <script is:inline>
      (() => {
        const storageKey = "acm-theme";
        const root = document.documentElement;
        let theme = "dark";

        try {
          const stored = localStorage.getItem(storageKey);
          if (stored === "light" || stored === "dark") {
            theme = stored;
          } else if (typeof window.matchMedia === "function" && window.matchMedia("(prefers-color-scheme: light)").matches) {
            theme = "light";
          }
        } catch {
          if (typeof window.matchMedia === "function" && window.matchMedia("(prefers-color-scheme: light)").matches) {
            theme = "light";
          }
        }

        root.setAttribute("data-theme", theme);
        root.style.colorScheme = theme;
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={resolvedDescription} />
    <meta name="theme-color" content="#080C10" />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/dragon-favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="acabreram.me" />
    <meta property="og:image" content={new URL("/og-image.png", siteUrl).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={new URL("/og-image.png", siteUrl).toString()} />

    <slot name="head" />
    <title>{resolvedTitle}</title>

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "acabreram.me",
          "url": siteUrl.toString(),
          "description": resolvedDescription,
          "inLanguage": lang
        },
        {
          "@type": "Person",
          "name": "Alex Cabrera",
          "alternateName": "Alejandro Cabrera Martínez",
          "url": siteUrl.toString(),
          "jobTitle": "Copilot Solution Engineer",
          "worksFor": { "@type": "Organization", "name": "Microsoft" },
          "sameAs": [
            "https://linkedin.com/in/alexcabreram",
            "https://github.com/alexcabreram"
          ],
          "knowsAbout": ["Azure", "AI Agents", "Docker", "Infrastructure as Code", "Cloud Architecture"]
        }
      ]
    })} />
  </head>
  <body class="min-h-screen bg-background text-text antialiased">
    <!-- Skip to content link — accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-sm focus:border focus:border-[var(--color-seiryu)] focus:bg-background focus:px-4 focus:py-2 focus:text-sm focus:text-[var(--color-seiryu)] focus:outline-none"
    >
      Skip to content
    </a>
    <div class="relative isolate overflow-x-clip">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[32rem]"
        style="background: radial-gradient(circle at top, var(--hero-radial), transparent 45%)"
      ></div>
      <slot />
    </div>
  </body>
</html>
