---
import Layout from "../../layouts/Layout.astro";
import { translations } from "../../i18n/translations";

const target = "/es/#about";
const t = translations.es.redirect;
---

<Layout lang="es" title={t.title} description={t.description}>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0;url=${target}`} />
  </Fragment>

  <section class="section-shell flex min-h-screen items-center justify-center py-24 text-center">
    <div class="reveal max-w-xl rounded-[1.75rem] border border-seiryu/20 bg-surface px-8 py-10">
      <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu">{t.label}</p>
      <h1 class="mt-4 font-display text-4xl text-text">{t.heading}</h1>
      <p class="mt-4 font-body text-lg leading-relaxed text-text/78">
        {t.bodyPrefix}
        <a href={target} class="text-seiryu hover:text-seiryu-hi"> {t.linkText}</a>.
      </p>
    </div>
  </section>
</Layout>
