---
import Layout from "../../../layouts/Layout.astro";
import BlogNav from "../../../components/BlogNav.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => {
  return !data.draft && data.lang === "es";
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });

const getReadingTime = (body: string | undefined) => Math.max(1, Math.ceil((body?.split(/\s+/).length ?? 0) / 230));
---

<Layout lang="es" title="Blog — acabreram.me" description="Posts sobre infraestructura, agentes de IA, arquitectura cloud y experimentos con homelab.">
  <BlogNav lang="es" />

  <main id="main-content">
    <section class="py-10 sm:py-16">
      <div class="section-shell">
        <p
          class="mb-2 font-mono text-[10px] uppercase tracking-[0.2em]"
          style="color: var(--color-seiryu)"
        >
          Blog
        </p>
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-text sm:text-4xl">
          Posts
        </h1>
        <p class="mb-10 max-w-xl text-sm text-muted">
          Infraestructura, agentes de IA, arquitectura cloud y experimentos con homelab. Redactados con agentes de IA, publicados por un humano.
        </p>

        {posts.length === 0 ? (
          <p class="text-sm text-muted italic">Aún no hay posts. El primero está en camino.</p>
        ) : (
          <div class="flex flex-col gap-6">
            {posts.map((post) => (
              <a
                href={`/es/blog/${post.id.replace('es/', '')}/`}
                class="group block overflow-hidden border border-[var(--border-subtle)] transition-colors hover:border-[var(--color-seiryu)]"
                style="border-radius: 2px"
              >
                <img
                  src={post.data.heroImage ?? `/og/${post.id}.png`}
                  alt={post.data.title}
                  loading="lazy"
                  decoding="async"
                  class="aspect-[2.5/1] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                />
                <div class="p-5 sm:p-6">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  {post.data.tags.map((tag: string) => (
                    <span class="font-mono text-[10px] uppercase tracking-wider text-seiryu">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-lg font-semibold text-text group-hover:text-seiryu transition-colors sm:text-xl">
                  {post.data.title}
                </h2>
                <p class="mt-1.5 text-sm text-muted line-clamp-2">
                  {post.data.description}
                </p>
                <div class="mt-3 flex items-center gap-3">
                  <time class="font-mono text-[11px] text-muted/60">
                    {formatDate(post.data.date)}
                  </time>
                  <span class="font-mono text-[11px] text-muted/40">· {getReadingTime(post.body)} min</span>
                </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>
