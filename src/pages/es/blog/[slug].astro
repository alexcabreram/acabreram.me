---
import Layout from "../../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft && data.lang === "es");
  return posts.map((post) => ({
    params: { slug: post.id.replace('es/', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
  date.toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });
---

<Layout
  lang="es"
  title={`${post.data.title} — acabreram.me`}
  description={post.data.description}
>
  <main id="main-content">
    <article class="py-20 sm:py-24">
      <div class="section-shell max-w-2xl">
        <div class="mb-6">
          <a href="/es/blog/" class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-muted transition-colors hover:text-seiryu">
            <span>←</span> Todos los posts
          </a>
        </div>

        <header class="mb-10">
          <div class="flex flex-wrap items-center gap-2 mb-3">
            {post.data.tags.map((tag: string) => (
              <span class="font-mono text-[10px] uppercase tracking-wider text-seiryu">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-2xl font-bold tracking-tight text-text sm:text-3xl lg:text-4xl">
            {post.data.title}
          </h1>
          <div class="mt-3 flex items-center gap-3">
            <time class="font-mono text-[11px] text-muted/60">
              {formatDate(post.data.date)}
            </time>
            {post.data.updatedDate && (
              <span class="font-mono text-[11px] text-muted/40">
                · Actualizado {formatDate(post.data.updatedDate)}
              </span>
            )}
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>

        <footer class="mt-14 border-t pt-6" style="border-color: var(--border-subtle)">
          <a href="/es/blog/" class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-muted transition-colors hover:text-seiryu">
            <span>←</span> Todos los posts
          </a>
        </footer>
      </div>
    </article>
  </main>
</Layout>
