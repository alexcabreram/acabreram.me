---
import Layout from "../../layouts/Layout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

const timeline = [
  "Derecho - UC3M y UAH",
  "Call center -> IT Support",
  "M365 Developer -> Tech Lead en Sogeti",
  "Copilot Solution Engineer en Microsoft Spain"
];

const routing = [
  ["Como despliego Copilot en una empresa?", "Enterprise mode"],
  ["Que modelo local corre mejor en Mac Mini?", "Homelab mode"],
  ["Como enseno IA sin sonar a marketing?", "Profesor mode"],
  ["Puedo automatizar esto con n8n?", "Builder mode"]
];
---

<Layout lang="es" title="Proto A - Neo Editorial Dragon" description="Prototipo editorial de la landing personal.">
  <main>
    <header class="neo-header">
      <div class="section-shell neo-header__inner">
        <a href="#top" class="brand-mark inline-flex items-center gap-3 font-mono text-base font-semibold tracking-[0.28em] text-seiryu-hi">
          <img src="/dragon-nav.png" alt="Dragon" class="h-8 w-8" />
          <span>acm.</span>
        </a>
        <nav class="neo-nav" aria-label="Navegacion prototipo A">
          <a href="#about">About</a>
          <a href="#routing">Routing</a>
          <a href="/es/blog/">Blog</a>
          <a href="https://www.linkedin.com/in/alexcabreram/" target="_blank" rel="noreferrer">LinkedIn</a>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <section id="top" class="section-shell neo-hero">
      <p class="font-ui text-xs uppercase tracking-[0.34em] text-seiryu">Neo Editorial Dragon</p>
      <h1 class="neo-title">Alex Cabrera</h1>
      <p class="neo-tagline">
        Enterprise AI by day. Rogue homelab by night.
      </p>
      <div class="neo-ctas">
        <a href="#about" class="control-pill px-5 py-3">About</a>
        <a href="#routing" class="control-pill px-5 py-3">Prompt routing</a>
      </div>
    </section>

    <section id="about" class="section-shell neo-section">
      <p class="font-mono text-xs tracking-[0.2em] text-seiryu">FROM LAW TO CLOUD</p>
      <h2 class="font-display text-4xl text-text sm:text-5xl">From Law school to Cloud Engineering - the scenic route.</h2>
      <p class="mt-4 max-w-3xl font-body text-lg leading-relaxed text-text/86">
        Soy Alex. Ayudo a empresas a desplegar IA con gobernanza y foco real de negocio.
        Por la noche construyo agentes y automatizaciones locales en un stack propio.
      </p>

      <div class="neo-grid mt-10">
        <ol class="timeline space-y-5 pl-8">
          {
            timeline.map((item, idx) => (
              <li class="relative">
                <span class:list={["timeline-dot", idx === timeline.length - 1 && "timeline-dot--active"]}></span>
                <p class="font-body text-lg text-text/82">{item}</p>
              </li>
            ))
          }
        </ol>

        <div class="neo-split">
          <article class="surface-card rounded-sm bg-surface p-6">
            <p class="font-mono text-xs tracking-[0.2em] text-seiryu">BY DAY</p>
            <p class="mt-3 font-body text-base leading-relaxed text-text/82">
              Copilot strategy, governance y adopcion enterprise con CIOs y CISOs.
            </p>
          </article>
          <article class="surface-card rounded-sm bg-surface p-6">
            <p class="font-mono text-xs tracking-[0.2em] text-seiryu-hi">BY NIGHT</p>
            <p class="mt-3 font-body text-base leading-relaxed text-text/82">
              Agentes locales, n8n, Telegram y observabilidad sobre NAS y Mac Mini.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section id="routing" class="section-shell neo-section">
      <p class="font-mono text-xs tracking-[0.2em] text-seiryu-hi">PROMPT ROUTING - COMO PIENSO</p>
      <div class="neo-routing mt-6">
        {
          routing.map(([question, mode]) => (
            <div class="neo-route-row">
              <span class="neo-question">{question}</span>
              <span class="neo-arrow">-></span>
              <span class="neo-mode">{mode}</span>
            </div>
          ))
        }
      </div>
    </section>

    <footer class="neo-footer">
      <div class="section-shell neo-footer__inner">
        <div>
          <p class="font-mono text-sm tracking-[0.2em] text-seiryu">acm.</p>
          <p class="mt-2 font-body text-base text-text/78">Built with Astro. Designed for readability first.</p>
        </div>
        <div class="neo-footer__links">
          <a href="/rss.xml">RSS</a>
          <a href="/es/blog/">Blog</a>
          <a href="https://www.linkedin.com/in/alexcabreram/" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .neo-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--border-subtle);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(8px);
  }

  .neo-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4.75rem;
  }

  .neo-nav {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 78%, transparent);
  }

  .neo-nav a:hover {
    color: var(--seiryu-hi);
  }

  .neo-hero {
    padding-block: 5rem 3rem;
  }

  .neo-title {
    margin-top: 0.65rem;
    font-family: var(--font-display);
    font-size: clamp(2.9rem, 8vw, 5.8rem);
    line-height: 1.02;
    color: var(--text);
  }

  .neo-title:hover {
    text-shadow: 0 0 20px color-mix(in srgb, var(--seiryu-hi) 35%, transparent);
  }

  .neo-tagline {
    margin-top: 1rem;
    max-width: 40rem;
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 2.8vw, 1.7rem);
    line-height: 1.5;
    color: color-mix(in srgb, var(--text) 88%, transparent);
  }

  .neo-ctas {
    margin-top: 1.6rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .neo-section {
    padding-block: 2.6rem;
  }

  .neo-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1.2fr 1fr;
  }

  .neo-split {
    display: grid;
    gap: 1rem;
  }

  .timeline {
    position: relative;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.5625rem;
    top: 0.45rem;
    bottom: 0.45rem;
    width: 1px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--seiryu-hi) 40%, transparent), color-mix(in srgb, var(--seiryu) 10%, transparent));
  }

  .timeline-dot {
    position: absolute;
    left: -1.95rem;
    top: 0.52rem;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--seiryu-hi) 55%, transparent);
    background: var(--bg);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--seiryu) 12%, transparent);
  }

  .timeline-dot--active {
    background: var(--seiryu-hi);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--seiryu-hi) 30%, transparent), 0 0 16px color-mix(in srgb, var(--seiryu-hi) 60%, transparent);
  }

  .neo-routing {
    border: 1px solid var(--border-subtle);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    border-radius: 2px;
    overflow: hidden;
  }

  .neo-route-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .neo-route-row:last-child {
    border-bottom: 0;
  }

  .neo-question {
    font-family: var(--font-body);
    color: color-mix(in srgb, var(--text) 82%, transparent);
  }

  .neo-arrow,
  .neo-mode {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--seiryu-hi);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .neo-footer {
    margin-top: 3rem;
    border-top: 1px solid var(--border-subtle);
    padding-block: 1.8rem;
  }

  .neo-footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .neo-footer__links {
    display: flex;
    gap: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 86%, transparent);
  }

  .neo-footer__links a:hover {
    color: var(--seiryu-hi);
  }

  @media (max-width: 900px) {
    .neo-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .neo-nav {
      gap: 0.45rem;
      font-size: 0.6rem;
      letter-spacing: 0.06em;
    }

    .neo-route-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .neo-arrow {
      display: none;
    }
  }
</style>
