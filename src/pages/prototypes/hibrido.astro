---
import Layout from "../../layouts/Layout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

const cards = [
  { src: "/dragon-hero.png", name: "dragon-hero" },
  { src: "/dragon-nav.png", name: "dragon-nav" },
  { src: "/dragon-favicon.png", name: "dragon-favicon" },
  { src: "/dragon.png", name: "dragon" }
];

const routes = [
  ["Copilot strategy in enterprise", "Enterprise mode"],
  ["Local agents and model tuning", "Homelab mode"],
  ["Teaching AI with critical thinking", "Profesor mode"],
  ["Workflow automation with n8n", "Builder mode"]
];
---

<Layout lang="es" title="Proto B - Hibrido Neo + Glass" description="Prototipo hibrido con glass, carrusel y efectos.">
  <main>
    <header class="hy-header" id="top">
      <div class="section-shell hy-header__inner">
        <a href="#top" class="brand-mark inline-flex items-center gap-3 font-mono text-base font-semibold tracking-[0.28em] text-seiryu-hi">
          <img src="/dragon-nav.png" alt="Dragon" class="h-9 w-9" />
          <span class="hy-logo">acm.</span>
        </a>

        <nav class="hy-nav" aria-label="Navegacion prototipo B">
          <a href="#about">About</a>
          <a href="#gallery">Gallery</a>
          <a href="#routing">Routing</a>
          <a href="/es/blog/">Blog</a>
          <a href="https://www.linkedin.com/in/alexcabreram/" target="_blank" rel="noreferrer">LinkedIn</a>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <section class="section-shell hy-hero">
      <p class="font-ui text-xs uppercase tracking-[0.34em] text-seiryu">Hibrido Neo + Glass Ops</p>
      <h1 class="hy-title" data-scramble data-target="Alex Cabrera">Alex Cabrera</h1>
      <p class="hy-tagline">
        Governance, AI systems y un stack dragon-ready en un solo flujo.
      </p>
      <div class="hy-cta-row">
        <a href="#gallery" class="control-pill px-5 py-3">Ver carrusel</a>
        <a href="#routing" class="control-pill px-5 py-3">Ver routing</a>
      </div>
    </section>

    <section id="gallery" class="hy-gallery-wrap">
      <div class="section-shell">
        <p class="font-mono text-xs tracking-[0.2em] text-seiryu-hi">DRAGON ASSET CAROUSEL</p>
        <div class="hy-carousel mt-6">
          <div class="hy-track">
            {
              [...cards, ...cards].map((card, idx) => (
                <figure class="hy-card" aria-label={card.name + " " + idx}>
                  <img src={card.src} alt={card.name} loading="lazy" decoding="async" />
                  <figcaption>{card.name}</figcaption>
                </figure>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section-shell hy-section">
      <h2 class="font-display text-4xl text-text sm:text-5xl">From Law school to Cloud Engineering - scenic route, real outcomes.</h2>
      <div class="hy-day-night mt-8">
        <article class="hy-glass-card">
          <p class="font-mono text-xs tracking-[0.2em] text-seiryu">BY DAY</p>
          <p class="mt-3 font-body text-base leading-relaxed text-text/82">Copilot adoption, governance architecture and enterprise execution.</p>
        </article>
        <article class="hy-glass-card">
          <p class="font-mono text-xs tracking-[0.2em] text-seiryu-hi">BY NIGHT</p>
          <p class="mt-3 font-body text-base leading-relaxed text-text/82">Local models, Telegram agents, n8n automations and observability loops.</p>
        </article>
      </div>
    </section>

    <section id="routing" class="section-shell hy-section">
      <p class="font-mono text-xs tracking-[0.2em] text-seiryu-hi">PROMPT ROUTING - HOW I THINK</p>
      <div class="hy-routing mt-5">
        {
          routes.map(([q, m]) => (
            <div class="hy-route-row">
              <span>{q}</span>
              <span class="hy-route-arrow">-></span>
              <strong>{m}</strong>
            </div>
          ))
        }
      </div>
    </section>

    <button id="dragon-follower-toggle" class="hy-follower-toggle" type="button" aria-pressed="false" aria-label="Activar dragon follower">
      <img src="/dragon-favicon.png" alt="Dragon follower" />
    </button>
    <img id="dragon-follower" src="/dragon-favicon.png" alt="" aria-hidden="true" class="hy-follower" />

    <footer class="hy-footer">
      <div class="section-shell hy-footer__inner">
        <p class="font-body text-base text-text/82">Built with Astro. Glass touches, clear reading, mobile-aware.</p>
        <div class="hy-footer__links">
          <a href="/rss.xml">RSS</a>
          <a href="/es/blog/">Blog</a>
          <a href="https://www.linkedin.com/in/alexcabreram/" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script is:inline>
  (() => {
    const CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
    const targets = document.querySelectorAll("[data-scramble]");

    const scramble = (el) => {
      const target = el.dataset.target || el.textContent || "";
      let frame = 0;
      const iv = setInterval(() => {
        el.textContent = target
          .split("")
          .map((c, i) => (i < frame ? c : CHARS[Math.floor(Math.random() * CHARS.length)]))
          .join("");
        if (frame >= target.length) {
          clearInterval(iv);
        }
        frame += 0.5;
      }, 38);
    };

    setTimeout(() => {
      targets.forEach(scramble);
    }, 350);

    const toggle = document.getElementById("dragon-follower-toggle");
    const follower = document.getElementById("dragon-follower");
    if (!toggle || !follower || ("ontouchstart" in window)) {
      if (follower) follower.style.display = "none";
      if (toggle) toggle.style.display = "none";
      return;
    }

    let active = false;
    let mx = window.innerWidth * 0.5;
    let my = window.innerHeight * 0.5;
    let fx = mx;
    let fy = my;

    document.addEventListener("mousemove", (event) => {
      mx = event.clientX;
      my = event.clientY;
    });

    toggle.addEventListener("click", () => {
      active = !active;
      toggle.setAttribute("aria-pressed", String(active));
      toggle.setAttribute("aria-label", active ? "Desactivar dragon follower" : "Activar dragon follower");
      follower.style.opacity = active ? "0.95" : "0";
    });

    const tick = () => {
      if (active) {
        fx += (mx - fx) * 0.07;
        fy += (my - fy) * 0.07;
        follower.style.transform = `translate(${fx}px, ${fy}px)`;
      }
      requestAnimationFrame(tick);
    };

    tick();
  })();
</script>

<style>
  .hy-header {
    position: sticky;
    top: 0;
    z-index: 45;
    border-bottom: 1px solid color-mix(in srgb, var(--seiryu) 24%, var(--border-subtle));
    background: color-mix(in srgb, var(--bg) 74%, transparent);
    backdrop-filter: blur(16px) saturate(140%);
  }

  .hy-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 5rem;
  }

  .hy-logo {
    text-shadow: 0 0 18px color-mix(in srgb, var(--seiryu-hi) 45%, transparent);
  }

  .hy-nav {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 84%, transparent);
  }

  .hy-nav a:hover {
    color: var(--seiryu-hi);
  }

  .hy-hero {
    padding-block: 5rem 3.2rem;
  }

  .hy-title {
    margin-top: 0.7rem;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1.02;
    color: var(--text);
  }

  .hy-title:hover {
    text-shadow: 0 0 12px color-mix(in srgb, var(--seiryu-hi) 44%, transparent), 2px 0 0 color-mix(in srgb, var(--seiryu) 30%, transparent), -2px 0 0 color-mix(in srgb, var(--jade) 20%, transparent);
  }

  .hy-tagline {
    margin-top: 1rem;
    max-width: 40rem;
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2.7vw, 1.6rem);
    line-height: 1.48;
    color: color-mix(in srgb, var(--text) 86%, transparent);
  }

  .hy-cta-row {
    margin-top: 1.7rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hy-gallery-wrap {
    padding-block: 1rem 2rem;
  }

  .hy-carousel {
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--seiryu) 26%, var(--border-subtle));
    background: color-mix(in srgb, var(--surface) 84%, transparent);
    border-radius: 4px;
  }

  .hy-track {
    display: flex;
    width: max-content;
    animation: hy-scroll 24s linear infinite;
  }

  .hy-track:hover {
    animation-play-state: paused;
  }

  .hy-card {
    position: relative;
    width: 14rem;
    aspect-ratio: 16/10;
    border-right: 1px solid var(--border-subtle);
    overflow: hidden;
  }

  .hy-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hy-card:hover img {
    transform: scale(1.11);
  }

  .hy-card figcaption {
    position: absolute;
    left: 0.5rem;
    bottom: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text) 96%, transparent);
    background: color-mix(in srgb, var(--bg) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--seiryu) 28%, transparent);
    padding: 0.22rem 0.35rem;
  }

  .hy-section {
    padding-block: 2.5rem;
  }

  .hy-day-night {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .hy-glass-card {
    border: 1px solid color-mix(in srgb, var(--seiryu) 20%, var(--border-subtle));
    background: color-mix(in srgb, var(--surface-2) 72%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--seiryu-hi) 14%, transparent), 0 24px 45px color-mix(in srgb, var(--seiryu) 9%, transparent);
    backdrop-filter: blur(10px);
    border-radius: 4px;
    padding: 1.2rem;
  }

  .hy-routing {
    border: 1px solid color-mix(in srgb, var(--seiryu) 26%, var(--border-subtle));
    border-radius: 4px;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
  }

  .hy-route-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 0.65rem;
    align-items: center;
    padding: 0.78rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-body);
    color: color-mix(in srgb, var(--text) 84%, transparent);
  }

  .hy-route-row:last-child {
    border-bottom: 0;
  }

  .hy-route-arrow,
  .hy-route-row strong {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--seiryu-hi);
  }

  .hy-follower-toggle {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--seiryu) 30%, var(--border-subtle));
    background: color-mix(in srgb, var(--surface) 84%, transparent);
    box-shadow: 0 10px 26px color-mix(in srgb, var(--seiryu) 20%, transparent);
    display: grid;
    place-items: center;
    backdrop-filter: blur(12px);
  }

  .hy-follower-toggle img {
    width: 1.4rem;
    height: 1.4rem;
  }

  .hy-follower {
    position: fixed;
    left: 0;
    top: 0;
    width: 1.35rem;
    height: 1.35rem;
    transform: translate(-100px, -100px);
    pointer-events: none;
    z-index: 55;
    opacity: 0;
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--seiryu-hi) 45%, transparent));
  }

  .hy-footer {
    margin-top: 2.7rem;
    border-top: 1px solid color-mix(in srgb, var(--seiryu) 18%, var(--border-subtle));
    padding-block: 1.6rem;
  }

  .hy-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .hy-footer__links {
    display: flex;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--text) 86%, transparent);
  }

  .hy-footer__links a:hover {
    color: var(--seiryu-hi);
  }

  @keyframes hy-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 900px) {
    .hy-day-night {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .hy-nav {
      gap: 0.45rem;
      font-size: 0.6rem;
      letter-spacing: 0.06em;
    }

    .hy-card {
      width: 11.75rem;
    }

    .hy-route-row {
      grid-template-columns: 1fr;
      gap: 0.28rem;
    }

    .hy-route-arrow {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hy-track {
      animation: none;
    }

    .hy-card img {
      transition: none;
    }

    .hy-title:hover {
      text-shadow: none;
    }
  }
</style>
