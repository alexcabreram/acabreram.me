---
import Layout from "../layouts/Layout.astro";
import { translations, type Locale } from "../i18n/translations";
import LangToggle from "./LangToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = translations[lang];

const nasServices = ["Prometheus", "Grafana", "Alertmanager", "Sonarr", "Radarr", "Jellyfin", "AdGuard", "NPM", "n8n"];
const macMiniServices = ["Ollama", "Open WebUI", "OpenClaw", "GitHub Actions Runner"];
const aboutPhotos = [
  {
    src: "/photos/speaking-microsoft.jpg",
    alt: 'Alex presenting "Copilot Control System" at a Microsoft event.',
    className: "col-span-2 row-span-2 lg:col-span-2",
    imageClass: "object-center"
  },
  {
    src: "/photos/profile.jpg",
    alt: "Professional headshot of Alex Cabrera Martínez in a blazer.",
    className: "row-span-2",
    imageClass: "object-center"
  },
  {
    src: "/photos/microsoft-campus.jpg",
    alt: "Alex at the Microsoft campus with a giant Microsoft logo.",
    className: "row-span-1",
    imageClass: "object-center"
  },
  {
    src: "/photos/gaming-casual.jpg",
    alt: "Alex with Minecraft plushies, celebrating gaming culture.",
    className: "row-span-2",
    imageClass: "object-top"
  },
  {
    src: "/photos/conference-working.jpg",
    alt: "Alex working on a laptop at the Bizz Summit conference.",
    className: "row-span-1",
    imageClass: "object-center"
  }
];
---

<Layout lang={lang}>
  <main>
    <section id="top" class="relative flex min-h-screen items-center overflow-hidden">
      <div class="section-shell relative flex w-full items-center justify-center py-28">
        <img
          src="/dragon.png"
          alt=""
          aria-hidden="true"
          class="hero-dragon absolute -right-16 top-1/2 hidden w-[26rem] -translate-y-1/2 select-none lg:block xl:w-[34rem]"
        />

        <div class="absolute left-0 top-8 sm:top-10">
          <div
            aria-hidden="true"
            class="absolute -left-8 -top-8 h-28 w-28 rounded-full blur-2xl"
            style="background: radial-gradient(circle, color-mix(in srgb, var(--seiryu-hi) 32%, transparent) 0%, color-mix(in srgb, var(--seiryu) 18%, transparent) 40%, transparent 74%)"
          ></div>
          <a href="#top" class="brand-mark relative inline-flex items-center gap-3 font-mono text-base font-semibold tracking-[0.34em] text-seiryu-hi sm:text-lg">
            <img src="/dragon.png" alt="Seiryū" class="wordmark-dragon h-6 w-6" />
            <span>acm.</span>
          </a>
        </div>

        <div class="absolute right-0 top-8 flex items-center gap-3 sm:top-10">
          <ThemeToggle />
          <LangToggle />
        </div>

        <div class="reveal relative max-w-5xl text-left">
          <div class="flex flex-col gap-6 sm:gap-8 lg:flex-row lg:items-center lg:gap-10">
            <img
              src="/photos/profile.jpg"
              alt="Portrait of Alex Cabrera Martínez."
              loading="eager"
              fetchpriority="high"
              class="h-24 w-24 shrink-0 rounded-full border object-cover object-center sm:h-28 sm:w-28 lg:h-32 lg:w-32"
              style="border-color: var(--border-strong); box-shadow: var(--shadow-photo)"
            />
            <div>
              <p class="mb-6 font-ui text-xs font-medium uppercase tracking-[0.34em] text-muted sm:text-sm">
                {t.hero.role}
              </p>
              <h1 class="max-w-4xl font-display text-5xl leading-tight text-text sm:text-6xl lg:text-7xl">
                {t.hero.name}
              </h1>
              <p class="mt-6 max-w-3xl font-body text-xl italic leading-relaxed text-text/88 sm:text-2xl">
                {t.hero.tagline}
              </p>
            </div>
          </div>
          <div class="mt-10 flex flex-wrap gap-4 font-ui text-sm font-medium text-text sm:text-base">
            <a
              href="/blog"
              class="control-pill inline-flex items-center gap-2 rounded-full px-5 py-3 hover:-translate-y-0.5 hover:text-seiryu-hi"
            >
              {t.hero.cta.blog} →
            </a>
            <a
              href="https://github.com/alexcabreram"
              target="_blank"
              rel="noreferrer"
              class="control-pill inline-flex items-center gap-2 rounded-full px-5 py-3 hover:-translate-y-0.5 hover:text-seiryu-hi"
            >
              {t.hero.cta.github} →
            </a>
            <a
              href="https://www.linkedin.com/in/alexcabreram/"
              target="_blank"
              rel="noreferrer"
              class="control-pill inline-flex items-center gap-2 rounded-full px-5 py-3 hover:-translate-y-0.5 hover:text-seiryu-hi"
            >
              {t.hero.cta.linkedin} →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="build" class="py-24 sm:py-28">
      <div class="section-shell">
        <div class="reveal max-w-2xl">
          <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.build.label}</p>
          <h2 class="mt-4 font-display text-4xl leading-tight text-text sm:text-5xl">{t.build.title}</h2>
          <p class="mt-5 font-body text-lg leading-relaxed text-text/80">
            {t.build.description}
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            t.build.cards.map((card, index) => (
              <article class="reveal surface-card group rounded-[1.75rem] bg-surface p-7 transition duration-300 hover:-translate-y-1">
                <div class="flex items-start gap-4">
                  <span class="font-mono text-3xl font-medium tracking-[0.18em] text-seiryu/60">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <div>
                    <h3 class="font-ui text-xl font-semibold text-text">{card.title}</h3>
                  </div>
                </div>
                <p class="mt-5 font-body text-lg leading-relaxed text-text/78">{card.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="stack" class="py-24 sm:py-28">
      <div class="section-shell">
        <div class="reveal max-w-3xl">
          <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.stack.label}</p>
          <h2 class="mt-4 font-display text-4xl leading-tight text-text sm:text-5xl">{t.stack.title}</h2>
          <p class="mt-5 font-body text-lg leading-relaxed text-text/80">
            {t.stack.description}
          </p>
        </div>

        <div class="relative mt-14">
          <div
            aria-hidden="true"
            class="absolute inset-x-[18%] top-1/2 hidden h-px -translate-y-1/2 bg-gradient-to-r from-jade/35 via-gold/75 to-seiryu/35 lg:block"
          ></div>
          <div class="relative grid gap-6 lg:grid-cols-[1fr_auto_1fr] lg:items-center">
            <article class="reveal rounded-[2rem] border border-jade/20 bg-surface p-8 transition duration-300 hover:-translate-y-1 hover:border-jade/35" style="box-shadow: var(--shadow-jade)">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="font-ui text-xs font-medium uppercase tracking-[0.3em] text-jade">{t.stack.infraLabel}</p>
                  <h3 class="mt-3 font-display text-3xl text-text">UGREEN DXP2800 NAS</h3>
                </div>
                <span class="rounded-full border border-jade/25 bg-jade/10 px-3 py-1 font-mono text-xs text-jade">{t.stack.tags.infra}</span>
              </div>
              <div class="mt-8 flex flex-wrap gap-3">
                {
                  nasServices.map((service) => (
                    <span class="rounded-full border border-jade/20 bg-jade/10 px-3 py-2 font-ui text-sm text-jade">{service}</span>
                  ))
                }
              </div>
            </article>

            <div class="reveal flex justify-center">
              <div class="rounded-[1.75rem] border border-gold/30 bg-surface-2 px-7 py-6 text-center" style="box-shadow: var(--shadow-gold)">
                <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-gold">{t.stack.botLabel}</p>
                <h3 class="mt-3 font-mono text-lg font-semibold text-text">@homelabguardbot</h3>
                <div class="mt-4 flex flex-wrap justify-center gap-2">
                  <span class="rounded-full border border-gold/25 bg-gold/10 px-3 py-1.5 font-ui text-xs text-gold">{t.stack.tags.multiAgent}</span>
                  <span class="rounded-full border border-gold/25 bg-gold/10 px-3 py-1.5 font-ui text-xs text-gold">{t.stack.tags.topics}</span>
                </div>
              </div>
            </div>

            <article class="reveal rounded-[2rem] border border-seiryu/20 bg-surface p-8 transition duration-300 hover:-translate-y-1 hover:border-seiryu/35" style="box-shadow: var(--shadow-seiryu)">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="font-ui text-xs font-medium uppercase tracking-[0.3em] text-seiryu">{t.stack.aiLabel}</p>
                  <h3 class="mt-3 font-display text-3xl text-text">Mac Mini</h3>
                </div>
                <span class="rounded-full border border-seiryu/25 bg-seiryu/10 px-3 py-1 font-mono text-xs text-seiryu">{t.stack.tags.ai}</span>
              </div>
              <div class="mt-8 flex flex-wrap gap-3">
                {
                  macMiniServices.map((service) => (
                    <span class="rounded-full border border-seiryu/20 bg-seiryu/10 px-3 py-2 font-ui text-sm text-seiryu">{service}</span>
                  ))
                }
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="py-24 sm:py-28">
      <div class="section-shell">
        <div class="reveal max-w-3xl">
          <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.about.label}</p>
          <h2 class="mt-4 font-display text-4xl leading-tight text-text sm:text-5xl">
            {t.about.title}
          </h2>
          <p class="mt-6 font-body text-xl leading-relaxed text-text/82">
            {t.about.description}
          </p>
        </div>

        <div class="mt-12 grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <div class="reveal grid auto-rows-[7rem] grid-cols-2 gap-3 sm:auto-rows-[9rem] sm:gap-4 lg:grid-cols-3 lg:auto-rows-[8rem] xl:auto-rows-[9.25rem]">
            {
              aboutPhotos.map((photo) => (
                <figure class:list={["photo-tile group rounded-2xl hover:scale-[1.015]", photo.className]}>
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    loading="lazy"
                    decoding="async"
                    class:list={["h-full w-full object-cover transition duration-500", photo.imageClass]}
                  />
                </figure>
              ))
            }
          </div>

          <div class="space-y-8">
            <ol class="timeline reveal space-y-6 pl-8">
              {
                t.about.storyPoints.map((point) => (
                  <li class="relative">
                    <span class="timeline-dot absolute -left-[1.93rem] top-2 h-3 w-3 rounded-full border border-seiryu-hi/60 bg-background"></span>
                    <p class="font-body text-lg leading-relaxed text-text/80">{point}</p>
                  </li>
                ))
              }
            </ol>

            <p class="reveal rounded-[1.75rem] border border-seiryu/18 bg-surface/80 p-7 font-body text-xl italic leading-relaxed text-text/82" style="box-shadow: var(--shadow-soft)">
              {t.about.careerPath}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10 sm:py-14">
      <div class="section-shell">
        <div class="reveal text-center">
          <img src="/dragon.png" alt="" aria-hidden="true" class="closing-dragon mx-auto h-10 w-10" />
          <p class="mt-5 font-display text-3xl leading-tight text-seiryu sm:text-4xl">{t.footer.closing}</p>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t py-10" style="border-color: var(--border-subtle)">
    <div class="section-shell text-center">
      <p class="font-mono text-sm tracking-[0.22em] text-seiryu">acm.</p>
      <p class="mt-4 font-body text-base text-muted">
        {t.footer.builtWith}
      </p>
      <p class="mt-2 font-body text-base italic text-muted">
        {t.footer.posts}
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-5 font-ui text-sm font-medium text-text/80">
        <a href="https://github.com/alexcabreram" target="_blank" rel="noreferrer" class="hover:text-seiryu-hi">GitHub</a>
        <a href="https://www.linkedin.com/in/alexcabreram/" target="_blank" rel="noreferrer" class="hover:text-seiryu-hi">LinkedIn</a>
        <a href="#" class="hover:text-seiryu-hi">RSS</a>
      </div>
    </div>
  </footer>
</Layout>
