---
import Layout from "../layouts/Layout.astro";
import { translations, type Locale } from "../i18n/translations";
import LangToggle from "./LangToggle.astro";
import StackFlowConnector from "./StackFlowConnector.astro";
import StackServiceChip from "./StackServiceChip.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang: Locale;
}

type ServiceIcon =
  | "prometheus"
  | "grafana"
  | "alertmanager"
  | "sonarr"
  | "radarr"
  | "jellyfin"
  | "adguard"
  | "npm"
  | "n8n"
  | "ollama"
  | "openWebui"
  | "openclaw"
  | "githubActions"
  | "azureOpenAI"
  | "githubCopilot"
  | "cloudflare"
  | "claudeCode";

type ServiceEntry = {
  label: string;
  icon: ServiceIcon;
};

const { lang } = Astro.props;
const t = translations[lang];

type CertEntry = {
  name: string;
  code: string;
  badge: string;
};

const certifications: CertEntry[] = [
  { name: "Microsoft Certified Trainer", code: "MCT", badge: "/badges/mct.png" },
  { name: "Power Automate RPA Developer", code: "PL-500", badge: "/badges/pl-500.png" },
  { name: "Power Platform Fundamentals", code: "PL-900", badge: "/badges/pl-900.png" },
  { name: "Security, Compliance & Identity Fundamentals", code: "SC-900", badge: "/badges/sc-900.png" },
  { name: "Microsoft 365 Fundamentals", code: "MS-900", badge: "/badges/ms-900.png" },
  { name: "Professional Scrum Master I", code: "PSM I", badge: "/badges/psm-i.png" }
];

const nasServices: ServiceEntry[] = [
  { label: "Prometheus", icon: "prometheus" },
  { label: "Grafana", icon: "grafana" },
  { label: "Alertmanager", icon: "alertmanager" },
  { label: "Sonarr", icon: "sonarr" },
  { label: "Radarr", icon: "radarr" },
  { label: "Jellyfin", icon: "jellyfin" },
  { label: "AdGuard", icon: "adguard" },
  { label: "NPM", icon: "npm" },
  { label: "n8n", icon: "n8n" }
];
const macMiniServices: ServiceEntry[] = [
  { label: "Ollama", icon: "ollama" },
  { label: "Open WebUI", icon: "openWebui" },
  { label: "OpenClaw", icon: "openclaw" },
  { label: "GitHub Actions Runner", icon: "githubActions" }
];
const cloudServices: ServiceEntry[] = [
  { label: "Azure OpenAI", icon: "azureOpenAI" },
  { label: "GitHub Copilot", icon: "githubCopilot" },
  { label: "GitHub Actions", icon: "githubActions" },
  { label: "Cloudflare", icon: "cloudflare" },
  { label: "Claude Code", icon: "claudeCode" }
];
const aboutPhotos = [
  {
    src: "/photos/speaking-microsoft.jpg",
    alt: 'Alex presenting "Copilot Control System" at a Microsoft event.',
    className: "col-span-2 row-span-2",
    imageClass: "object-center"
  },
  {
    src: "/photos/profile.jpg",
    alt: "Professional headshot of Alex Cabrera Martínez in a blazer.",
    className: "row-span-2",
    imageClass: "object-center"
  },
  {
    src: "/photos/microsoft-campus.jpg",
    alt: "Alex at the Microsoft campus with a giant Microsoft logo.",
    className: "col-span-1 row-span-1",
    imageClass: "object-center"
  },
  {
    src: "/photos/gaming-casual.jpg",
    alt: "Alex with Minecraft plushies — gaming culture is part of the identity.",
    className: "col-span-1 row-span-1",
    imageClass: "object-center"
  },
  {
    src: "/photos/conference-working.jpg",
    alt: "Alex working on a laptop at the Bizz Summit conference.",
    className: "col-span-1 row-span-1",
    imageClass: "object-center"
  }
];
---

<Layout lang={lang}>
  <main id="main-content">
    <!-- Fix 6: reduce hero dead space — use min-h-[85vh] and push content up -->
    <section id="top" aria-label="Hero" class="relative flex min-h-[85vh] items-center overflow-hidden">
      <div class="section-shell relative flex w-full items-center justify-center py-20 sm:py-24">
        <img
          src="/dragon-hero.png"
          alt=""
          aria-hidden="true"
          class="hero-dragon absolute -right-16 top-1/2 hidden w-[26rem] -translate-y-1/2 select-none lg:block xl:w-[34rem]"
        />

        <div class="absolute left-0 top-8 sm:top-10">
          <div
            aria-hidden="true"
            class="absolute -left-8 -top-8 h-28 w-28 rounded-full blur-2xl"
            style="background: radial-gradient(circle, color-mix(in srgb, var(--seiryu-hi) 32%, transparent) 0%, color-mix(in srgb, var(--seiryu) 18%, transparent) 40%, transparent 74%)"
          ></div>
          <a href="#top" class="brand-mark relative inline-flex items-center gap-3 font-mono text-base font-semibold tracking-[0.34em] text-seiryu-hi sm:text-lg">
            <img src="/seiryu-favicon.svg" alt="Seiryū" width="29" height="28" />
            <span class="text-text">acm<span class="text-seiryu-hi">.</span></span>
          </a>
        </div>

        <div class="absolute right-0 top-8 flex items-center gap-3 sm:top-10">
          <ThemeToggle />
          <LangToggle />
        </div>

        <div class="reveal relative max-w-5xl text-left">
          <div class="flex flex-col gap-6 sm:gap-8 lg:flex-row lg:items-center lg:gap-10">
            <img
              src="/photos/profile.jpg"
              alt="Portrait of Alex Cabrera Martínez."
              loading="eager"
              fetchpriority="high"
              class="h-24 w-24 shrink-0 rounded-full border object-cover object-center sm:h-28 sm:w-28 lg:h-32 lg:w-32"
              style="border-color: var(--border-strong); box-shadow: var(--shadow-photo)"
            />
            <div>
              <p class="mb-6 font-ui text-xs font-medium uppercase tracking-[0.34em] text-muted sm:text-sm">
                {t.hero.role}
              </p>
              <h1 class="max-w-4xl font-display text-5xl leading-tight text-text sm:text-6xl lg:text-7xl">
                {t.hero.name}
              </h1>
              <p class="mt-6 max-w-3xl font-body text-xl italic leading-relaxed text-text/88 sm:text-2xl">
                {t.hero.tagline}
              </p>
            </div>
          </div>
          <div class="mt-10 flex flex-wrap gap-4 font-ui text-sm font-medium text-text sm:text-base">
            <a
              href={lang === "es" ? "/es/blog" : "/blog"}
              class="control-pill inline-flex items-center gap-2 px-5 py-3 hover:-translate-y-0.5 hover:text-seiryu-hi"
            >
              {t.hero.cta.blog} →
            </a>
            <a
              href="https://github.com/alexcabreram"
              target="_blank"
              rel="noreferrer"
              class="control-pill inline-flex items-center gap-2 px-5 py-3 hover:-translate-y-0.5 hover:text-seiryu-hi"
            >
              {t.hero.cta.github} →
            </a>
            <a
              href="https://www.linkedin.com/in/alexcabreram/"
              target="_blank"
              rel="noreferrer"
              class="control-pill inline-flex items-center gap-2 px-5 py-3 hover:-translate-y-0.5 hover:text-seiryu-hi"
            >
              {t.hero.cta.linkedin} →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="build" aria-label="What I Build" class="py-14 sm:py-18">
      <div class="section-shell">
        <div class="reveal max-w-2xl">
          <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.build.label}</p>
          <h2 class="mt-4 font-display text-4xl leading-tight text-text sm:text-5xl">{t.build.title}</h2>
          <p class="mt-5 font-body text-lg leading-relaxed text-text/80">
            {t.build.description}
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            t.build.cards.map((card, index) => (
              <article class="reveal surface-card group rounded-sm bg-surface p-7 transition duration-300 hover:-translate-y-1">
                <div class="flex items-start gap-4">
                  <span class="font-mono text-3xl font-medium tracking-[0.18em] text-seiryu/60">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <div>
                    <h3 class="font-ui text-xl font-semibold text-text">{card.title}</h3>
                  </div>
                </div>
                <p class="mt-5 font-body text-lg leading-relaxed text-text/78">{card.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="stack" aria-label="The Stack" class="py-14 sm:py-18">
      <div class="section-shell">
        <div class="reveal max-w-3xl">
          <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.stack.label}</p>
          <h2 class="mt-4 font-display text-4xl leading-tight text-text sm:text-5xl">{t.stack.title}</h2>
          <p class="mt-5 font-body text-lg leading-relaxed text-text/80">
            {t.stack.description}
          </p>
        </div>

        <div class="mt-14 flex flex-col items-center gap-5">
          <!-- Cloud node -->
          <article class="reveal stack-node w-full max-w-2xl rounded-sm bg-surface p-8 transition duration-300 hover:-translate-y-1.5" style="--stack-accent: var(--seiryu-hi); --stack-shadow: var(--shadow-seiryu)">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="font-ui text-xs font-medium uppercase tracking-[0.3em] text-seiryu-hi">{t.stack.cloudLabel}</p>
                <h3 class="mt-3 font-display text-3xl text-text">Azure & Cloud</h3>
              </div>
              <span class="stack-meta-chip rounded-sm px-3 py-1 font-mono text-xs" style="--stack-accent: var(--seiryu-hi)">{t.stack.tags.cloud}</span>
            </div>
            <div class="mt-8 stack-service-grid text-seiryu-hi">
              {
                cloudServices.map((service) => <StackServiceChip label={service.label} icon={service.icon} tone="seiryu-hi" />)
              }
            </div>
          </article>

          <StackFlowConnector direction="vertical" colorStart="#00D4FF" colorEnd="#E8C96A" />

          <!-- Local infrastructure row -->
          <div class="grid w-full gap-5 lg:grid-cols-[minmax(0,1fr)_5.5rem_15rem_5.5rem_minmax(0,1fr)] lg:items-center">
            <article class="reveal stack-node rounded-sm bg-surface p-8 transition duration-300 hover:-translate-y-1.5" style="--stack-accent: var(--jade); --stack-shadow: var(--shadow-jade)">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="font-ui text-xs font-medium uppercase tracking-[0.3em] text-jade">{t.stack.infraLabel}</p>
                  <h3 class="mt-3 font-display text-3xl text-text">UGREEN DXP2800 NAS</h3>
                </div>
                <span class="stack-meta-chip rounded-sm px-3 py-1 font-mono text-xs" style="--stack-accent: var(--jade)">{t.stack.tags.infra}</span>
              </div>
              <div class="mt-8 stack-service-grid text-jade">
                {
                  nasServices.map((service) => <StackServiceChip label={service.label} icon={service.icon} tone="jade" />)
                }
              </div>
            </article>

            <StackFlowConnector direction="horizontal" colorStart="#2ECC8A" colorEnd="#E8C96A" />

            <article class="reveal stack-node rounded-sm bg-surface-2 px-7 py-7 text-center transition duration-300 hover:-translate-y-1.5" style="--stack-accent: var(--gold); --stack-shadow: var(--shadow-gold)">
              <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-sm border border-gold/20 bg-gold/10 text-gold">
                <svg viewBox="0 0 16 16" class="h-6 w-6 fill-current" aria-hidden="true">
                  <path d="M2 5.5C2 4.7 2.7 4 3.5 4h9c.8 0 1.5.7 1.5 1.5v5c0 .8-.7 1.5-1.5 1.5h-3L8 14l-1.5-2H3.5C2.7 12 2 11.3 2 10.5v-5ZM4.5 6.5h7v1h-7v-1Zm0 2h4.5v1H4.5v-1Z"></path>
                </svg>
              </div>
              <p class="mt-5 font-ui text-xs font-medium uppercase tracking-[0.34em] text-gold">{t.stack.botLabel}</p>
              <h3 class="mt-3 font-mono text-lg font-semibold text-text">@homelabguardbot</h3>
              <div class="mt-5 flex flex-wrap justify-center gap-2.5">
                <span class="stack-meta-chip rounded-sm px-3 py-1.5 font-ui text-xs" style="--stack-accent: var(--gold)">{t.stack.tags.multiAgent}</span>
                <span class="stack-meta-chip rounded-sm px-3 py-1.5 font-ui text-xs" style="--stack-accent: var(--gold)">{t.stack.tags.topics}</span>
              </div>
            </article>

            <StackFlowConnector direction="horizontal" colorStart="#E8C96A" colorEnd="#00B4D8" />

            <article class="reveal stack-node rounded-sm bg-surface p-8 transition duration-300 hover:-translate-y-1.5" style="--stack-accent: var(--seiryu); --stack-shadow: var(--shadow-seiryu)">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="font-ui text-xs font-medium uppercase tracking-[0.3em] text-seiryu">{t.stack.aiLabel}</p>
                  <h3 class="mt-3 font-display text-3xl text-text">Mac Mini</h3>
                </div>
                <span class="stack-meta-chip rounded-sm px-3 py-1 font-mono text-xs" style="--stack-accent: var(--seiryu)">{t.stack.tags.ai}</span>
              </div>
              <div class="mt-8 stack-service-grid text-seiryu">
                {
                  macMiniServices.map((service) => <StackServiceChip label={service.label} icon={service.icon} tone="seiryu" />)
                }
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="about" aria-label="About" class="py-14 sm:py-18">
      <div class="section-shell">
        <div class="reveal max-w-3xl">
          <p class="font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.about.label}</p>
          <p class="mt-5 font-mono text-[10px] font-medium uppercase tracking-[0.2em] text-seiryu">
            {t.about.fullName}
          </p>
          <h2 class="mt-5 font-display text-4xl leading-tight text-text sm:text-5xl">
            {t.about.title}
          </h2>
          <p class="mt-6 font-body text-xl leading-relaxed text-text/82">
            {t.about.description}
          </p>
        </div>

        <div class="mt-12 grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <div class="reveal grid auto-rows-[7rem] grid-cols-2 gap-3 sm:auto-rows-[9rem] sm:gap-4 lg:grid-cols-3 lg:auto-rows-[8rem] xl:auto-rows-[9.25rem]">
            {
              aboutPhotos.map((photo) => (
                <figure class:list={["photo-tile group rounded-sm hover:scale-[1.015]", photo.className]}>
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    loading="lazy"
                    decoding="async"
                    class:list={["h-full w-full object-cover transition duration-500", photo.imageClass]}
                  />
                </figure>
              ))
            }
          </div>

          <div class="space-y-8">
            <ol class="timeline reveal space-y-6 pl-8">
              {
                t.about.storyPoints.map((point) => (
                  <li class="relative">
                    <span class="timeline-dot absolute -left-[1.93rem] top-2 h-3 w-3 rounded-full border border-seiryu-hi/60 bg-background"></span>
                    <p class="font-body text-lg leading-relaxed text-text/80">{point}</p>
                  </li>
                ))
              }
            </ol>

            <p class="reveal rounded-sm border border-seiryu/18 bg-surface/80 p-7 font-body text-xl italic leading-relaxed text-text/82" style="box-shadow: var(--shadow-soft)">
              {t.about.careerPath}
            </p>
          </div>
        </div>

        <!-- Certifications -->
        <div class="reveal mt-14">
          <p class="mb-6 font-ui text-xs font-medium uppercase tracking-[0.34em] text-seiryu sm:text-sm">{t.about.certsLabel}</p>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {
              certifications.map((cert) => (
                <div class="cert-badge group flex items-center gap-4 rounded-sm p-4 transition duration-200 hover:-translate-y-0.5">
                  <img
                    src={cert.badge}
                    alt={cert.name}
                    loading="lazy"
                    decoding="async"
                    class="h-14 w-14 shrink-0 object-contain"
                  />
                  <div class="min-w-0">
                    <span class="block font-mono text-xs font-semibold tracking-wider text-seiryu">{cert.code}</span>
                    <span class="block font-ui text-sm leading-snug text-text/76">{cert.name}</span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="py-6 sm:py-8">
      <div class="section-shell">
        <div class="reveal text-center">
          <img src="/dragon-hero.png" alt="" aria-hidden="true" class="closing-dragon mx-auto h-20 w-20 sm:h-24 sm:w-24" />
          <p class="mt-5 font-display text-3xl leading-tight text-seiryu sm:text-4xl">{t.footer.closing}</p>
          <a
            href={lang === "es" ? "/es/blog/" : "/blog/"}
            class="control-pill mt-6 inline-flex items-center gap-2 px-5 py-3 font-ui text-sm font-medium text-text hover:-translate-y-0.5 hover:text-seiryu-hi sm:text-base"
          >
            → {t.footer.ctaBlog}
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer role="contentinfo" class="border-t py-10" style="border-color: var(--border-subtle)">
    <div class="section-shell text-center">
      <div class="inline-flex items-center gap-2">
        <img src="/seiryu-favicon.svg" alt="" aria-hidden="true" class="h-4 w-4" />
        <span class="font-mono text-sm tracking-[0.22em] text-text">acm<span class="text-seiryu">.</span></span>
      </div>
      <p class="mt-4 font-body text-base text-muted">
        {t.footer.builtWith}
      </p>
      <p class="mt-2 font-body text-base italic text-muted">
        {t.footer.posts}
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-5 font-ui text-sm font-medium text-text/80">
        <a href="https://github.com/alexcabreram" target="_blank" rel="noreferrer" class="hover:text-seiryu-hi">GitHub</a>
        <a href="https://www.linkedin.com/in/alexcabreram/" target="_blank" rel="noreferrer" class="hover:text-seiryu-hi">LinkedIn</a>
        <a href="/rss.xml" class="hover:text-seiryu-hi">RSS</a>
      </div>
    </div>
  </footer>
</Layout>
