---
interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;
const isEs = lang === "es";

const nodes = [
  {
    id: "user",
    label: isEs ? "Tú" : "You",
    sublabel: isEs ? "El operador" : "The operator",
    icon: "👤",
    color: "#E8C96A",
    role: "user",
    detail: {
      title: isEs ? "Tú — El operador" : "You — The operator",
      body: isEs
        ? "Interactúas con el sistema completo a través de Telegram. Cualquier canal activa el agente correspondiente. El sistema aprende tu contexto."
        : "You interact with the full system through Telegram. Any channel triggers the matching agent. The system learns your context.",
      chips: isEs ? ["Telegram", "Contexto persistente", "Control total"] : ["Telegram", "Persistent context", "Full control"],
    },
  },
  {
    id: "bot",
    label: "@homelabguardbot",
    sublabel: isEs ? "Hub central · OpenClaw" : "Central hub · OpenClaw",
    icon: "🤖",
    color: "#00D4FF",
    role: "hub",
    detail: {
      title: "@homelabguardbot",
      body: isEs
        ? "Bot de Telegram multi-topic. Enruta cada mensaje al agente correcto según el canal. 5 agentes activos, memoria persistente, modelo local Ollama."
        : "Multi-topic Telegram bot. Routes each message to the correct agent by channel. 5 active agents, persistent memory, local Ollama model.",
      chips: ["OpenClaw", "5 agents", "Ollama gemma4:e4b", "Telegram Topics"],
    },
  },
  {
    id: "main",
    label: isEs ? "Asistente" : "Assistant",
    sublabel: "#assistant",
    icon: "💬",
    color: "#00D4FF",
    role: "agent",
    detail: {
      title: isEs ? "Agente main — Asistente general" : "Agent main — General assistant",
      body: isEs
        ? "Asistente de propósito general. Responde preguntas, genera contenido y actúa como IA conversacional via Telegram #assistant."
        : "General-purpose assistant. Answers questions, generates content, and acts as conversational AI via Telegram #assistant.",
      chips: ["Ollama local", "Chat general", "#assistant"],
      connections: ["bot", "devops"],
    },
  },
  {
    id: "monitor",
    label: isEs ? "Monitor" : "Monitor",
    sublabel: "#monitoring",
    icon: "📊",
    color: "#2ECC8A",
    role: "agent",
    detail: {
      title: isEs ? "Agente monitor — Alertas" : "Agent monitor — Alerts",
      body: isEs
        ? "Recibe alertas de Prometheus/Alertmanager y las reenvía al canal #monitoring. No responde automáticamente con LLM — solo notifica."
        : "Receives Prometheus/Alertmanager alerts and forwards to #monitoring. Does not auto-reply with LLM — notification only.",
      chips: ["Prometheus", "Alertmanager", "#monitoring", "Read-only"],
      connections: ["bot"],
    },
  },
  {
    id: "media",
    label: "Media",
    sublabel: "#media",
    icon: "🎬",
    color: "#a78bfa",
    role: "agent",
    detail: {
      title: isEs ? "Agente media — Contenido" : "Agent media — Content",
      body: isEs
        ? "Gestiona solicitudes a Jellyseerr para películas y series. Interactúa con Sonarr, Radarr y el NAS."
        : "Manages Jellyseerr requests for movies and series. Interacts with Sonarr, Radarr and the NAS.",
      chips: ["Jellyseerr", "Sonarr", "Radarr", "#media"],
      connections: ["bot"],
    },
  },
  {
    id: "devops",
    label: "DevOps",
    sublabel: "#devops",
    icon: "⚙️",
    color: "#f97316",
    role: "agent",
    detail: {
      title: isEs ? "Agente devops — Infraestructura" : "Agent devops — Infrastructure",
      body: isEs
        ? "Docker, redes, deploys. El comando /dev delega tareas al Claude Runner o crea issues para el Copilot Coding Agent en GitHub."
        : "Docker, networking, deploys. The /dev command delegates to Claude Runner or creates issues for the Copilot Coding Agent on GitHub.",
      chips: ["Claude Runner", "Copilot Agent", "Docker", "#devops", "/dev cmd"],
      connections: ["bot", "main", "ideas"],
    },
  },
  {
    id: "ideas",
    label: "Ideas",
    sublabel: "#ideas",
    icon: "💡",
    color: "#E8C96A",
    role: "agent",
    detail: {
      title: isEs ? "Agente ideas — Análisis de contenido" : "Agent ideas — Content analysis",
      body: isEs
        ? "Analiza URLs, artículos, vídeos de YouTube y PDFs. Usa IdeaScout (yt-dlp + Cobalt) para extraer contenido y Ollama para analizarlo."
        : "Analyzes URLs, articles, YouTube videos and PDFs. Uses IdeaScout (yt-dlp + Cobalt) to extract content and Ollama to analyze it.",
      chips: ["IdeaScout", "yt-dlp", "Cobalt", "Ollama", "#ideas"],
      connections: ["bot", "devops"],
    },
  },
];

// Cross-agent connections (pairs that interrelate)
const crossEdges = [
  ["main", "devops"],
  ["devops", "ideas"],
];
---

<div class="agent-graph-wrapper" id="agent-graph-wrapper">
  <div class="agent-graph-container" id="agent-graph-container">
    <svg id="agent-graph-svg" class="agent-graph-svg" viewBox="0 0 900 540" aria-label="Interactive agent architecture diagram" role="img">
      <defs>
        <filter id="glow-blue" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="6" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <filter id="glow-gold" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="5" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <filter id="glow-green" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="4" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <!-- Animated data packet markers -->
        <marker id="arrowhead" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
          <circle cx="4" cy="4" r="2" fill="rgba(0,212,255,0.7)" />
        </marker>
        <marker id="arrowhead-gold" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
          <circle cx="4" cy="4" r="2" fill="rgba(232,201,106,0.7)" />
        </marker>
      </defs>

      <!-- Will be populated by JS -->
      <g id="ag-edges"></g>
      <g id="ag-packets"></g>
      <g id="ag-nodes"></g>
    </svg>
  </div>

  <!-- Detail panel -->
  <aside class="agent-detail-panel" id="agent-detail-panel" aria-live="polite" aria-hidden="true">
    <button class="agent-detail-close" id="agent-detail-close" type="button" aria-label="Close panel">✕</button>
    <div id="agent-detail-inner"></div>
  </aside>
</div>

<script is:inline>
(function () {
  // ─── Node layout (positions in 900×540 viewBox) ───────────────────────────
  const positions = {
    user:    { x: 450, y: 480 },
    bot:     { x: 450, y: 300 },
    main:    { x: 130, y: 180 },
    monitor: { x: 290, y: 90  },
    media:   { x: 450, y: 60  },
    devops:  { x: 610, y: 90  },
    ideas:   { x: 770, y: 180 },
  };

  const nodeData = {
    user: {
      label: document.documentElement.lang === "es" ? "Tú" : "You",
      sublabel: document.documentElement.lang === "es" ? "El operador" : "The operator",
      icon: "👤", color: "#E8C96A", role: "user",
      detail: {
        title: document.documentElement.lang === "es" ? "Tú — El operador" : "You — The operator",
        body: document.documentElement.lang === "es"
          ? "Interactúas con el sistema completo a través de Telegram. Cualquier canal activa el agente correspondiente."
          : "You interact with the full system through Telegram. Any channel triggers the matching agent.",
        chips: document.documentElement.lang === "es"
          ? ["Telegram", "Contexto persistente", "Control total"]
          : ["Telegram", "Persistent context", "Full control"],
      },
    },
    bot: {
      label: "@homelabguardbot",
      sublabel: "OpenClaw · Hub",
      icon: "🤖", color: "#00D4FF", role: "hub",
      detail: {
        title: "@homelabguardbot",
        body: document.documentElement.lang === "es"
          ? "Bot de Telegram multi-topic. Enruta cada mensaje al agente correcto. 5 agentes activos, memoria persistente, modelo Ollama local."
          : "Multi-topic Telegram bot. Routes each message to the correct agent. 5 active agents, persistent memory, local Ollama model.",
        chips: ["OpenClaw", "5 agents", "Ollama gemma4:e4b", "Telegram Topics"],
      },
    },
    main: {
      label: document.documentElement.lang === "es" ? "Asistente" : "Assistant",
      sublabel: "#assistant",
      icon: "💬", color: "#00D4FF", role: "agent",
      detail: {
        title: document.documentElement.lang === "es" ? "Agente main" : "Agent main",
        body: document.documentElement.lang === "es"
          ? "Asistente de propósito general. Chat conversacional via Telegram #assistant. Colabora con DevOps para tareas técnicas."
          : "General-purpose assistant. Conversational chat via Telegram #assistant. Collaborates with DevOps for technical tasks.",
        chips: ["Ollama local", "Chat general", "#assistant"],
      },
    },
    monitor: {
      label: "Monitor",
      sublabel: "#monitoring",
      icon: "📊", color: "#2ECC8A", role: "agent",
      detail: {
        title: document.documentElement.lang === "es" ? "Agente monitor" : "Agent monitor",
        body: document.documentElement.lang === "es"
          ? "Recibe alertas de Prometheus/Alertmanager y las reenvía a #monitoring. Solo notifica, no responde con LLM."
          : "Receives Prometheus/Alertmanager alerts, forwards to #monitoring. Notification only — no LLM auto-reply.",
        chips: ["Prometheus", "Alertmanager", "#monitoring", "Read-only"],
      },
    },
    media: {
      label: "Media",
      sublabel: "#media",
      icon: "🎬", color: "#a78bfa", role: "agent",
      detail: {
        title: document.documentElement.lang === "es" ? "Agente media" : "Agent media",
        body: document.documentElement.lang === "es"
          ? "Gestiona solicitudes a Jellyseerr para películas y series. Interactúa con Sonarr, Radarr y el NAS."
          : "Manages Jellyseerr requests for movies and series. Interacts with Sonarr, Radarr and the NAS.",
        chips: ["Jellyseerr", "Sonarr", "Radarr", "#media"],
      },
    },
    devops: {
      label: "DevOps",
      sublabel: "#devops",
      icon: "⚙️", color: "#f97316", role: "agent",
      detail: {
        title: document.documentElement.lang === "es" ? "Agente devops" : "Agent devops",
        body: document.documentElement.lang === "es"
          ? "Docker, redes, deploys. /dev delega al Claude Runner o crea issues para el Copilot Coding Agent en GitHub."
          : "Docker, networking, deploys. /dev delegates to Claude Runner or creates issues for Copilot Coding Agent on GitHub.",
        chips: ["Claude Runner", "Copilot Agent", "Docker", "#devops", "/dev"],
      },
    },
    ideas: {
      label: "Ideas",
      sublabel: "#ideas",
      icon: "💡", color: "#E8C96A", role: "agent",
      detail: {
        title: document.documentElement.lang === "es" ? "Agente ideas" : "Agent ideas",
        body: document.documentElement.lang === "es"
          ? "Analiza URLs, vídeos de YouTube, artículos y PDFs con IdeaScout (yt-dlp + Cobalt) y Ollama local."
          : "Analyzes URLs, YouTube videos, articles and PDFs with IdeaScout (yt-dlp + Cobalt) and local Ollama.",
        chips: ["IdeaScout", "yt-dlp", "Cobalt", "Ollama", "#ideas"],
      },
    },
  };

  // Edges: [from, to, type]
  // type: "main" = user→bot, "hub" = bot→agent, "cross" = agent↔agent
  const edges = [
    ["user", "bot", "main"],
    ["bot", "main", "hub"],
    ["bot", "monitor", "hub"],
    ["bot", "media", "hub"],
    ["bot", "devops", "hub"],
    ["bot", "ideas", "hub"],
    ["main", "devops", "cross"],
    ["devops", "ideas", "cross"],
  ];

  const svg = document.getElementById("agent-graph-svg");
  const edgesG = document.getElementById("ag-edges");
  const packetsG = document.getElementById("ag-packets");
  const nodesG = document.getElementById("ag-nodes");
  const panel = document.getElementById("agent-detail-panel");
  const panelInner = document.getElementById("agent-detail-inner");
  const closeBtn = document.getElementById("agent-detail-close");

  if (!svg || !edgesG || !packetsG || !nodesG || !panel || !panelInner || !closeBtn) return;

  // ─── Draw edges ────────────────────────────────────────────────────────────
  const drawnEdges = [];

  edges.forEach(([from, to, type]) => {
    const p1 = positions[from];
    const p2 = positions[to];
    const mid = { x: (p1.x + p2.x) / 2, y: (p1.y + p2.y) / 2 };

    // Control point for slight curve
    const dx = p2.x - p1.x;
    const dy = p2.y - p1.y;
    const cx = mid.x - dy * 0.18;
    const cy = mid.y + dx * 0.18;

    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    const d = `M ${p1.x} ${p1.y} Q ${cx} ${cy} ${p2.x} ${p2.y}`;

    let stroke = "rgba(0,212,255,0.18)";
    let dasharray = "none";
    if (type === "main") { stroke = "rgba(232,201,106,0.35)"; }
    if (type === "cross") { stroke = "rgba(255,255,255,0.10)"; dasharray = "6 5"; }

    path.setAttribute("d", d);
    path.setAttribute("fill", "none");
    path.setAttribute("stroke", stroke);
    path.setAttribute("stroke-width", type === "main" ? "2" : "1.5");
    if (dasharray !== "none") path.setAttribute("stroke-dasharray", dasharray);
    path.setAttribute("class", `ag-edge ag-edge--${type}`);
    path.dataset.from = from;
    path.dataset.to = to;
    edgesG.appendChild(path);

    // Animated packet on hub/main edges
    if (type !== "cross") {
      const pathLen = path.getTotalLength ? path.getTotalLength() : 200;
      const packet = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      packet.setAttribute("r", "3.5");
      packet.setAttribute("fill", type === "main" ? "#E8C96A" : (nodeData[to]?.color || "#00D4FF"));
      packet.setAttribute("opacity", "0.85");
      packet.setAttribute("class", "ag-packet");
      packet.dataset.pathId = `agpath-${from}-${to}`;

      // Animate along path
      const anim = document.createElementNS("http://www.w3.org/2000/svg", "animateMotion");
      anim.setAttribute("dur", (1.8 + Math.random() * 1.4).toFixed(1) + "s");
      anim.setAttribute("repeatCount", "indefinite");
      anim.setAttribute("begin", (Math.random() * 2).toFixed(1) + "s");
      const mpath = document.createElementNS("http://www.w3.org/2000/svg", "mpath");
      path.setAttribute("id", `agpath-${from}-${to}`);
      mpath.setAttributeNS("http://www.w3.org/1999/xlink", "xlink:href", `#agpath-${from}-${to}`);
      anim.appendChild(mpath);
      packet.appendChild(anim);
      packetsG.appendChild(packet);
    }

    drawnEdges.push({ from, to, type, el: path });
  });

  // ─── Draw nodes ────────────────────────────────────────────────────────────
  const NODE_R = {
    user: 34,
    hub: 44,
    agent: 38,
  };

  Object.entries(positions).forEach(([id, pos]) => {
    const data = nodeData[id];
    if (!data) return;
    const r = NODE_R[data.role];
    const color = data.color;

    const g = document.createElementNS("http://www.w3.org/2000/svg", "g");
    g.setAttribute("class", `ag-node ag-node--${data.role}`);
    g.setAttribute("data-id", id);
    g.setAttribute("tabindex", "0");
    g.setAttribute("role", "button");
    g.setAttribute("aria-label", data.label);
    g.setAttribute("transform", `translate(${pos.x}, ${pos.y})`);
    g.style.cursor = "pointer";

    // Pulse ring (hub only)
    if (data.role === "hub") {
      [1, 2].forEach((i) => {
        const ring = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        ring.setAttribute("r", r + 14 + i * 12);
        ring.setAttribute("fill", "none");
        ring.setAttribute("stroke", color);
        ring.setAttribute("stroke-width", "1");
        ring.setAttribute("opacity", "0");
        ring.setAttribute("class", `ag-ring ag-ring--${i}`);

        const animOpacity = document.createElementNS("http://www.w3.org/2000/svg", "animate");
        animOpacity.setAttribute("attributeName", "opacity");
        animOpacity.setAttribute("values", "0;0.35;0");
        animOpacity.setAttribute("dur", (2.4 + i * 0.8) + "s");
        animOpacity.setAttribute("repeatCount", "indefinite");
        animOpacity.setAttribute("begin", (i * 0.6) + "s");
        ring.appendChild(animOpacity);

        const animR = document.createElementNS("http://www.w3.org/2000/svg", "animate");
        animR.setAttribute("attributeName", "r");
        animR.setAttribute("values", `${r + 8}; ${r + 28 + i * 10}; ${r + 8}`);
        animR.setAttribute("dur", (2.4 + i * 0.8) + "s");
        animR.setAttribute("repeatCount", "indefinite");
        animR.setAttribute("begin", (i * 0.6) + "s");
        ring.appendChild(animR);

        g.appendChild(ring);
      });
    }

    // Outer glow circle
    const glow = document.createElementNS("http://www.w3.org/2000/svg", "circle");
    glow.setAttribute("r", r + 8);
    glow.setAttribute("fill", color);
    glow.setAttribute("opacity", data.role === "hub" ? "0.12" : "0.07");
    glow.setAttribute("class", "ag-glow");
    g.appendChild(glow);

    // Main circle
    const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
    circle.setAttribute("r", r);
    circle.setAttribute("fill", "var(--ag-bg, #0e1117)");
    circle.setAttribute("stroke", color);
    circle.setAttribute("stroke-width", data.role === "hub" ? "2.5" : "1.8");
    g.appendChild(circle);

    // Icon text (emoji)
    const iconEl = document.createElementNS("http://www.w3.org/2000/svg", "text");
    iconEl.setAttribute("text-anchor", "middle");
    iconEl.setAttribute("dominant-baseline", "central");
    iconEl.setAttribute("y", "-8");
    iconEl.setAttribute("font-size", data.role === "hub" ? "22" : "18");
    iconEl.textContent = data.icon;
    g.appendChild(iconEl);

    // Label text
    const labelEl = document.createElementNS("http://www.w3.org/2000/svg", "text");
    labelEl.setAttribute("text-anchor", "middle");
    labelEl.setAttribute("dominant-baseline", "central");
    labelEl.setAttribute("y", data.role === "hub" ? "12" : "10");
    labelEl.setAttribute("font-size", data.role === "hub" ? "8.5" : "9");
    labelEl.setAttribute("fill", color);
    labelEl.setAttribute("font-family", "var(--font-mono, monospace)");
    labelEl.setAttribute("font-weight", "600");
    labelEl.setAttribute("letter-spacing", "0.03em");
    labelEl.textContent = data.label.length > 16 ? data.label.slice(0, 15) + "…" : data.label;
    g.appendChild(labelEl);

    // Sublabel
    const subEl = document.createElementNS("http://www.w3.org/2000/svg", "text");
    subEl.setAttribute("text-anchor", "middle");
    subEl.setAttribute("dominant-baseline", "central");
    subEl.setAttribute("y", data.role === "hub" ? "22" : "20");
    subEl.setAttribute("font-size", "7");
    subEl.setAttribute("fill", "rgba(255,255,255,0.42)");
    subEl.setAttribute("font-family", "var(--font-mono, monospace)");
    subEl.textContent = data.sublabel;
    g.appendChild(subEl);

    // Interactions
    const activate = () => showDetail(id, data, color, g, pos);
    g.addEventListener("click", activate);
    g.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") activate(); });

    g.addEventListener("mouseenter", () => {
      glow.setAttribute("opacity", data.role === "hub" ? "0.22" : "0.16");
      circle.setAttribute("stroke-width", data.role === "hub" ? "3.5" : "2.8");
      highlightEdges(id, true);
    });
    g.addEventListener("mouseleave", () => {
      glow.setAttribute("opacity", data.role === "hub" ? "0.12" : "0.07");
      circle.setAttribute("stroke-width", data.role === "hub" ? "2.5" : "1.8");
      highlightEdges(id, false);
    });

    nodesG.appendChild(g);
  });

  // ─── Edge highlighting ─────────────────────────────────────────────────────
  function highlightEdges(nodeId, on) {
    drawnEdges.forEach(({ from, to, type, el }) => {
      if (from === nodeId || to === nodeId) {
        if (on) {
          el.setAttribute("stroke-width", "2.5");
          let color = "rgba(0,212,255,0.55)";
          if (type === "main") color = "rgba(232,201,106,0.65)";
          if (type === "cross") color = "rgba(255,255,255,0.28)";
          el.setAttribute("stroke", color);
        } else {
          el.setAttribute("stroke-width", type === "main" ? "2" : "1.5");
          let color = "rgba(0,212,255,0.18)";
          if (type === "main") color = "rgba(232,201,106,0.35)";
          if (type === "cross") color = "rgba(255,255,255,0.10)";
          el.setAttribute("stroke", color);
        }
      }
    });
  }

  // ─── Detail panel ──────────────────────────────────────────────────────────
  let activeNodeEl = null;

  function showDetail(id, data, color, groupEl, pos) {
    if (activeNodeEl) {
      activeNodeEl.classList.remove("is-selected");
      activeNodeEl.querySelector(".ag-glow")?.setAttribute("opacity", 
        activeNodeEl.dataset.role === "hub" ? "0.12" : "0.07");
    }
    groupEl.classList.add("is-selected");
    groupEl.querySelector(".ag-glow")?.setAttribute("opacity", "0.28");
    activeNodeEl = groupEl;

    const d = data.detail;
    panelInner.innerHTML = `
      <div class="agent-detail-header" style="--node-color: ${color}">
        <span class="agent-detail-icon">${data.icon}</span>
        <div>
          <p class="agent-detail-title">${d.title}</p>
          <p class="agent-detail-channel">${data.sublabel}</p>
        </div>
      </div>
      <p class="agent-detail-body">${d.body}</p>
      <div class="agent-detail-chips">
        ${d.chips.map(c => `<span class="agent-detail-chip" style="--node-color: ${color}">${c}</span>`).join("")}
      </div>
    `;

    panel.setAttribute("aria-hidden", "false");
    panel.classList.add("is-open");
  }

  closeBtn.addEventListener("click", () => {
    panel.classList.remove("is-open");
    panel.setAttribute("aria-hidden", "true");
    if (activeNodeEl) {
      activeNodeEl.classList.remove("is-selected");
      activeNodeEl.querySelector(".ag-glow")?.setAttribute("opacity",
        activeNodeEl.querySelector('[class*="ag-node--hub"]') ? "0.12" : "0.07");
      activeNodeEl = null;
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && panel.classList.contains("is-open")) {
      closeBtn.click();
    }
  });

})();
</script>
