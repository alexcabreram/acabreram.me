---

<span class="stack-service-chip inline-flex items-center gap-2.5 rounded-sm px-3.5 py-2.5 font-ui text-sm leading-none" style={toneStyle}>
  <span class="stack-service-chip__icon flex h-8 w-8 shrink-0 items-center justify-center rounded-sm" aria-hidden="true">
    <svg viewBox="0 0 16 16" class="h-4 w-4 fill-current" focusable="false">
      {
        iconMap[icon].map((node) =>
          node.tag === "path" ? (
            <path d={node.d}></path>
          ) : (
            <circle cx={node.cx} cy={node.cy} r={node.r}></circle>
          )
        )
      }
    </svg>
  </span>
  <span>{label}</span>
</span>
