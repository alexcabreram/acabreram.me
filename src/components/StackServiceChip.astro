---
interface PathNode {
  tag: "path";
  d: string;
}

interface CircleNode {
  tag: "circle";
  cx: number;
  cy: number;
  r: number;
}

type SvgNode = PathNode | CircleNode;
type IconName =
  | "prometheus"
  | "grafana"
  | "alertmanager"
  | "sonarr"
  | "radarr"
  | "jellyfin"
  | "adguard"
  | "npm"
  | "n8n"
  | "ollama"
  | "openWebui"
  | "openclaw"
  | "githubActions"
  | "azureOpenAI"
  | "githubCopilot"
  | "cloudflare"
  | "claudeCode";

interface Props {
  label: string;
  icon: IconName;
  tone: "jade" | "seiryu" | "azure";
}

const { label, icon, tone } = Astro.props;

const toneStyles: Record<string, string> = {
  jade: "--service-accent: var(--jade); --service-shadow: var(--shadow-jade);",
  seiryu: "--service-accent: var(--seiryu); --service-shadow: var(--shadow-seiryu);",
  "seiryu-hi": "--service-accent: var(--seiryu-hi); --service-shadow: var(--shadow-seiryu);",
  azure: "--service-accent: var(--azure); --service-shadow: var(--shadow-azure);"
};
const toneStyle = toneStyles[tone];

